# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for Socket.IO (production only)
ALLOWED_ORIGINS=http://localhost:3000

# ── Next.js Public Variables ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Socket.IO server URL (leave empty for same-origin, set to Railway URL on Vercel)
# Example: https://hometheter-production.up.railway.app
NEXT_PUBLIC_SOCKET_URL=
